# Copy to .env.local and fill in from the Supabase dashboard:
# Project Settings -> API. Both values are safe to expose in the browser.
VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# Server secrets (ANTHROPIC_API_KEY, STRIPE_SECRET_KEY, STRIPE_WEBHOOK_SECRET,
# STRAVA_CLIENT_ID, STRAVA_CLIENT_SECRET, RESEND_API_KEY) are NEVER put in this
# repo or in .env.local — they live only in the Supabase dashboard under
# Edge Functions -> Secrets.
